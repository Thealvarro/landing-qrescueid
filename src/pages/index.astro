---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "QRescueID",
    "url": "https://qrescueid.app",
    "logo": "https://qrescueid.app/img/favicon.ico",
    "description": "QRescueID guarda tu información médica y contactos vitales en un QR y NFC. Seguridad y tranquilidad en cada aventura.",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+56954751380",
      "contactType": "customer service",
      "availableLanguage": "Spanish"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "QRescueID",
    "url": "https://qrescueid.app"
  }
];
---

<BaseLayout
  title="QRescueID - Tu Identificación de Emergencia, Siempre Contigo"
  description="QRescueID guarda tu información médica y contactos vitales en un QR y NFC. Seguridad y tranquilidad en cada aventura."
  ogImage="/img/caja-qrescueid_resultado_optimized.webp"
  jsonLd={jsonLd}
>
  <Navbar />

  <!-- Hero -->
  <section class="hero-section">
    <div class="container">
      <div class="row align-items-center min-vh-100">
        <div class="col-lg-12 text-center" data-aos="fade-up">
          <h1 class="hero-title mb-4">
            Tu identificación de emergencia,<br>siempre contigo.
          </h1>
          <p class="hero-subtitle mb-5">
            QRescueID guarda tu información médica y contactos vitales en un QR y NFC.
          </p>
          <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="/planes/" class="btn btn-primary-yellow btn-lg">Crea tu cuenta gratis</a>
            <a href="https://plataforma.qrescueid.app/info/IE8WLJVP" target="_blank" class="btn btn-custom-red btn-lg">Ver Perfil demo</a>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-background"></div>
  </section>

  <!-- ¿Por qué QRescueID? -->
  <section class="why-section">
    <div class="container">
      <div class="row align-items-center py-5">
        <div class="col-lg-6 mb-5 mb-lg-0" data-aos="fade-right">
          <div class="content-block">
            <h2 class="section-heading mb-4">
              ¿Por qué <span class="highlight-yellow">QRescueID</span>?
            </h2>
            <p class="lead mb-4">Porque nadie debería quedar sin nombre en una emergencia.</p>
            <p class="mb-4">
              Si un día sufres un accidente y no puedes hablar, QRescueID habla por ti. Entrega tu nombre,
              tu información médica y a quién llamar, en segundos.
            </p>
            <p class="mb-4">
              No es solo tecnología. Es un acto de cuidado. Un escudo silencioso que puede marcar la
              diferencia entre la incertidumbre… y una respuesta rápida.
            </p>
            <a href="/planes/" class="btn btn-primary-yellow">Comprar</a>
          </div>
        </div>
        <div class="col-lg-6" data-aos="fade-left">
          <div class="image-container">
            <img src="/img/_MG_3496_resultado.webp" alt="Casco con QRescueID para identificación de emergencia" class="img-fluid rounded-4" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5 Razones -->
  <section class="reasons-section">
    <div class="container">
      <div class="row mb-5">
        <div class="col-lg-8 mx-auto text-center" data-aos="fade-up">
          <h2 class="section-heading mb-3">
            5 razones para utilizar <span class="highlight-yellow">QRescueID</span>
          </h2>
          <p class="text-muted">
            Tu casco puede hablar por ti cuando tú no puedes. Aquí te mostramos por qué cada vez más
            personas y empresas están eligiendo esta solución inteligente.
          </p>
        </div>
      </div>
      <div class="row g-4">
        {[
          { n: '01', title: 'Te identifica cuando tú no puedes hablar', text: 'En un accidente, el tiempo es oro. QRescueID entrega tu información médica y contactos de emergencia al instante con solo un escaneo.' },
          { n: '02', title: 'Funciona con cualquier celular', text: 'Sin apps, sin claves, sin complicaciones. Solo necesitas una cámara o NFC. Simple, rápido y universal.' },
          { n: '03', title: 'Pequeño, pero poderoso', text: 'Diseñado para cascos y superficies duras. Resistente al agua, al calor y al uso rudo. Siempre contigo, sin estorbar.' },
          { n: '04', title: 'Tranquilidad para ti y tu familia', text: 'Saber que alguien podrá contactarte o identificarte en segundos da una paz mental que no tiene precio. Protege lo que más importa.' },
          { n: '05', title: 'Ideal para trabajadores y deportistas', text: 'Desde faenas mineras hasta rutas en bicicleta. QRescueID está pensado para quienes se mueven, se exponen y no pueden darse el lujo de quedar sin nombre en una emergencia.' },
        ].map((item, i) => (
          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay={(i + 1) * 100}>
            <div class="feature-card h-100">
              <div class="feature-number">{item.n}</div>
              <h4 class="feature-title">{item.title}</h4>
              <p class="feature-text">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cuenta digital gratuita -->
  <section class="trust-section py-5">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-6 mb-5 mb-lg-0" data-aos="fade-right">
          <img src="/img/cel-plataforma-qrescueid-perfil_optimized.webp" alt="Crea tu cuenta gratis en QRescueID" class="img-fluid" />
        </div>
        <div class="col-lg-6" data-aos="fade-left">
          <h2 class="section-heading mb-4">
            ¿No tienes tu <span class="highlight-yellow">QRescueID físico</span>? <br>¡Crea tu cuenta igual!
          </h2>
          <p class="lead mb-4">Puedes registrarte totalmente gratis y obtener tu perfil de emergencia digital al instante.</p>
          <ul class="list-unstyled mb-4">
            {[
              'Crea tu cuenta digital sin costo.',
              'Genera e imprime tu propio código QR temporal.',
              'Pégalo en tu casco, billetera o donde prefieras.',
              'Si luego decides comprar el ID físico, podrás enlazarlo fácilmente a tu cuenta ya creada.',
            ].map(item => (
              <li class="mb-3 d-flex align-items-start">
                <i class="fas fa-check-circle text-warning mt-1 me-3"></i>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a href="https://plataforma.qrescueid.app/register" target="_blank" class="btn btn-primary-yellow btn-lg">Crear cuenta gratis</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Empresas que confían -->
  <section class="confian-section">
    <div class="container">
      <div class="row">
        <div class="col-12 text-center mb-5" data-aos="fade-up">
          <h2 class="section-heading mb-3">
            Empresas que <span class="highlight-yellow">confían</span> en QRescueID
          </h2>
          <p class="text-muted">Miles de empresas y deportistas ya confían en QRescueID para proteger a sus equipos</p>
        </div>
      </div>
      <div class="row justify-content-center">
        <div class="col-lg-10" data-aos="fade-up" data-aos-delay="100">
          <img src="/img/confian_optimized.webp" alt="Empresas que confían en QRescueID - identificación de emergencia" class="img-fluid rounded-4 d-none d-lg-block w-100 shadow-lg" />
          <img src="/img/confian-cel_optimized.webp" alt="Empresas que confían en QRescueID" class="img-fluid rounded-4 d-block d-lg-none w-100 shadow-lg" />
        </div>
      </div>
    </div>
  </section>

  <!-- Características -->
  <section class="explore-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-10 mx-auto text-center" data-aos="fade-up">
          <h2 class="section-heading mb-4">Confianza y tranquilidad en cada paso</h2>
          <p class="lead mb-5">
            Descubre cómo QRescueID puede hacer la diferencia en tu vida. Únete a la comunidad de
            deportistas y aventureros que ya disfrutan de la tranquilidad que solo QRescueID puede ofrecer.
          </p>
          <div class="row g-4 mt-4">
            {[
              { icon: 'fa-shield-alt', title: 'Resistente', text: 'QRescueID se adhiere a tu casco con pegamento ultra resistente 3M, así cuenta con una adherencia total.' },
              { icon: 'fa-mobile-alt', title: 'Tecnología NFC', text: 'Cuenta con un chip NFC NTAG 213 con una memoria total de 180 bytes, el chip más versátil y adecuado para este uso.' },
              { icon: 'fa-lock', title: 'Datos seguros', text: 'Tu información personal está segura en nuestra base de datos totalmente encriptada.' },
            ].map((item, i) => (
              <div class="col-md-4" data-aos="fade-up" data-aos-delay={(i + 1) * 100}>
                <div class="icon-box">
                  <i class={`fas ${item.icon} fa-3x mb-3`}></i>
                  <h5>{item.title}</h5>
                  <p>{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center" data-aos="fade-up">
          <h2 class="cta-title mb-4">Activa tu QRescueID hoy y ten tranquilidad en tus aventuras.</h2>
          <a href="/planes/" class="btn btn-dark-blue btn-lg">Comenzar ahora</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <section class="reviews-section">
    <div class="container">
      <div class="row mb-5">
        <div class="col-lg-8 mx-auto text-center" data-aos="fade-up">
          <h2 class="section-heading mb-3">
            Opiniones de <span class="highlight-yellow">Google</span>
          </h2>
          <div id="google-rating-summary" class="mt-3"></div>
        </div>
      </div>
      <div id="reviews-container" class="row g-4">
        <div class="col-12 text-center">
          <div class="spinner-border text-warning" role="status">
            <span class="visually-hidden">Cargando reseñas...</span>
          </div>
          <p class="text-muted mt-3">Cargando opiniones de Google...</p>
        </div>
      </div>
      <div class="row mt-5">
        <div class="col-12 text-center">
          <a href="https://www.google.com/maps/place/Qrescue+id/@-33.4248981,-70.6210462,17z/data=!4m8!3m7!1s0x9662d94c73f60935:0x50bfdb8dd5361f83!8m2!3d-33.4248981!4d-70.6184713!9m1!1b1!16s%2Fg%2F11t_8qls5q" target="_blank" class="btn btn-primary-yellow btn-lg">
            <i class="fas fa-star me-2"></i>Ver más comentarios en Google
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-10 mx-auto text-center" data-aos="fade-up">
          <h2 class="section-heading mb-4">
            QRescueID te da algo que todos necesitamos: <span class="highlight-yellow">tranquilidad</span>
          </h2>
          <p class="lead mb-4">Identificación inmediata. Contacto en segundos.</p>
          <p class="mb-5">Haz tu compra hoy como deportista. O contáctanos como empresa y cuidemos juntos a tu equipo.</p>
          <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/planes/" class="btn btn-primary-yellow btn-lg">Comprar ahora</a>
            <a href="/contacto/" class="btn btn-outline-yellow btn-lg">Contactar empresa</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <Fragment slot="body-end">
    <script is:inline>
      async function loadGoogleReviews() {
        const reviewsContainer = document.getElementById('reviews-container');
        const ratingSummary = document.getElementById('google-rating-summary');
        try {
          const response = await fetch('/api/reviews');
          const result = await response.json();
          if (result.success && result.data && result.data.reviews) {
            const rating = result.data.rating;
            const total = result.data.user_ratings_total;
            let starsHtml = '';
            for (let i = 1; i <= 5; i++) {
              if (i <= Math.floor(rating)) starsHtml += '<i class="fas fa-star text-warning"></i>';
              else if (i - 0.5 <= rating) starsHtml += '<i class="fas fa-star-half-alt text-warning"></i>';
              else starsHtml += '<i class="far fa-star text-warning"></i>';
            }
            if (ratingSummary) {
              ratingSummary.innerHTML = `<div class="d-flex flex-column align-items-center"><div class="h3 mb-1">${rating} ${starsHtml}</div><div class="text-muted small">Basado en ${total} opiniones en Google</div></div>`;
            }
            if (reviewsContainer) {
              reviewsContainer.innerHTML = '';
              result.data.reviews.forEach(function(review, index) {
                const initials = review.author_name.split(' ').map(function(n){ return n[0]; }).join('').toUpperCase().substring(0, 2);
                const stars = '<i class="fas fa-star text-warning"></i>'.repeat(review.rating);
                const seconds = Math.floor((new Date() - new Date(review.time * 1000)) / 1000);
                let timeAgo = 'Recientemente';
                let interval = seconds / 31536000;
                if (interval > 1) timeAgo = Math.floor(interval) + (Math.floor(interval) === 1 ? ' año atrás' : ' años atrás');
                else { interval = seconds / 2592000; if (interval > 1) timeAgo = Math.floor(interval) + ' meses atrás'; }
                reviewsContainer.insertAdjacentHTML('beforeend', `
                  <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="${index * 100}">
                    <div class="review-card h-100">
                      <div class="review-header">
                        <div class="review-avatar">${initials}</div>
                        <div><h5 class="mb-0">${review.author_name}</h5><small class="text-muted">${timeAgo}</small></div>
                      </div>
                      <div class="mb-2 text-warning" style="font-size:0.8rem;">${stars}</div>
                      <p class="review-text">${review.text}</p>
                    </div>
                  </div>`);
              });
              if (typeof AOS !== 'undefined') AOS.refresh();
            }
          } else {
            if (reviewsContainer) reviewsContainer.innerHTML = '<div class="col-12 text-center text-muted">No se pudieron cargar las reseñas en este momento.</div>';
          }
        } catch (error) {
          if (reviewsContainer) reviewsContainer.innerHTML = '<div class="col-12 text-center text-muted">Error conectando con la API de reseñas.</div>';
        }
      }
      document.addEventListener('DOMContentLoaded', loadGoogleReviews);
    </script>
  </Fragment>
</BaseLayout>
