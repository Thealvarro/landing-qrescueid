---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://qrescueid.app/" },
      { "@type": "ListItem", "position": 2, "name": "Tienda", "item": "https://qrescueid.app/tienda/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Productos QRescueID",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "url": "https://qrescueid.app/tienda/qrescueid-fisico/",
        "name": "QRescueID Físico"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "url": "https://qrescueid.app/tienda/kit-premium/",
        "name": "Kit Premium QRescueID"
      }
    ]
  }
];
---

<BaseLayout
  title="Tienda QRescueID - Sticker QR para Casco de Moto y Bicicleta"
  description="Compra tu sticker QR para casco. QRescueID físico desde $19.990 CLP o Kit Premium $36.990 CLP. QR y NFC de emergencia resistente al agua y adhesivo 3M."
  ogImage="/img/caja-qrescueid_resultado_optimized.webp"
  jsonLd={jsonLd}
>
  <Navbar />

  <!-- Hero Tienda -->
  <section class="plans-hero-section py-5">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center py-5 mt-5" data-aos="fade-up">
          <h1 class="section-heading mb-4">Nuestra <span class="highlight-yellow">Tienda</span></h1>
          <p class="lead text-muted">Productos QRescueID diseñados para darte tranquilidad en tus aventuras.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Productos -->
  <section class="products-section py-5">
    <div class="container">
      <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">

        <!-- QRescueID Físico -->
        <div class="col" data-aos="fade-up">
          <div class="card h-100 shadow-sm">
            <a href="/tienda/qrescueid-fisico/" class="text-decoration-none text-reset">
              <img src="/img/caja-qrescueid_resultado_optimized.webp" alt="QRescueID Físico - Identificación de emergencia con QR y NFC" class="card-img-top" style="height:220px;object-fit:cover;" />
            </a>
            <div class="card-body d-flex flex-column">
              <h2 class="card-title mb-2" style="font-size: 1.25rem;">
                <a href="/tienda/qrescueid-fisico/" class="text-decoration-none text-reset">QRescueID Físico</a>
              </h2>
              <p class="card-text text-muted mb-3">Identificación de emergencia física con QR y NFC.</p>
              <div class="mt-auto">
                <div class="pricing-price mb-3">
                  <span class="price-currency" style="color: var(--golden-yellow) !important;">$</span>
                  <span class="price-amount" style="color: var(--golden-yellow) !important;">19.990</span>
                  <span class="price-period">CLP</span>
                </div>
                <a href="/tienda/qrescueid-fisico/" class="btn btn-primary-yellow w-100">Ver detalles</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Kit Premium -->
        <div class="col" data-aos="fade-up" data-aos-delay="100">
          <div class="card h-100 shadow-sm">
            <a href="/tienda/kit-premium/" class="text-decoration-none text-reset">
              <img src="/img/casco-qrescueid-fluor-nocturno_resultado_optimized.webp" alt="Kit Premium QRescueID - 2 unidades físicas y Plan Premium" class="card-img-top" style="height:220px;object-fit:cover;" />
            </a>
            <div class="card-body d-flex flex-column">
              <h2 class="card-title mb-2" style="font-size: 1.25rem;">
                <a href="/tienda/kit-premium/" class="text-decoration-none text-reset">Kit Premium QRescueID</a>
              </h2>
              <p class="card-text text-muted mb-3">2 QRescueID físicos + 1 año Plan Premium.</p>
              <div class="mt-auto">
                <div class="mb-1">
                  <small class="text-decoration-line-through" style="color: var(--golden-yellow) !important;">$40.000</small>
                </div>
                <div class="pricing-price mb-3">
                  <span class="price-currency" style="color: var(--golden-yellow) !important;">$</span>
                  <span class="price-amount" style="color: var(--golden-yellow) !important;">36.990</span>
                  <span class="price-period">CLP</span>
                </div>
                <a href="/tienda/kit-premium/" class="btn btn-primary-yellow w-100">Ver detalles</a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
